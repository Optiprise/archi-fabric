    <element xsi:type="archimate:Artifact" name="artifactory/&lt;&lt;artifact>>.mjs" id="id-dc50a2b35dd64bcf960cc429fa74b2cf"/>
    <element xsi:type="archimate:SystemSoftware" name="Archi" id="id-3c0ec7d0818b46cb9a51ed4ffa648640"/>
    <element xsi:type="archimate:SystemSoftware" name="jArchi" id="id-b76f51699d7e4c8b9e2499b366e37002"/>
    <element xsi:type="archimate:SystemSoftware" name="archifabric" id="id-c3ff4d6c7730427b8df5a4f92813e470">
      <documentation>DocGen is a documentation generator that creates structured reports directly from models in Archi. It produces HTML pages enriched with CSS styling, tables, and tables of contents, which can then be converted into high-quality PDFs using WeasyPrint. Built in ECMAScript (JavaScript) and leveraging jArchi, DocGen provides a flexible way to transform architectural models into well-designed, professional documents.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="HTML5" id="id-d8dd7459b2384a6d985598c23388dea6"/>
    <element xsi:type="archimate:SystemSoftware" name="Weasyprint" id="id-e7fc109fd34a4f3e8a7dec55f1141e76">
      <documentation>WeasyPrint is a smart solution helping web developers to create PDF documents. It’s free and open source software that can be easily plugged to your applications and websites and turns simple HTML pages into gorgeous PDF-documents
</documentation>
    </element>
