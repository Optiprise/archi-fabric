              <documentation>@page {
	size: A4;
	@bottom-left {
		color: #214478;
		content: counter(page) &quot; of &quot; counter(pages) &quot; ArchiFabric&quot;;
		position: absolute;
		z-index: -1;
	}
}


html {
    color: #000000;
    font-family: 'Comfortaa';
    font-size: 9pt;
    font-weight: 300;
    line-height: 1.5;
	counter-reset: h2-counter;
  }

header {
    color: #000000;
    font-family: 'ComfortaaI';
    font-size: 9pt;
    font-weight: 300;
    line-height: 2.5;
	counter-reset: h2-counter;
  }

.header strong {
    font-family: 'Comfortaa';
    font-size: 6.5pt;
}

h1,h2,h3,h4 {
	color: #214478;
}

hr {
  border: 0.5px solid #214478;
}

h1 {
	break-before: page;
    font-size: 11pt;
    font-family: 'Comfortaa-Bold';
    string-set: heading content();
	counter-increment: h1-counter;
	counter-reset: h2-counter;
	text-transform: uppercase;
	font-weight: normal;
	position: relative; 
	padding-left: 1cm;
	margin-top: 50px;
}

h1::before {
 	content: counter(h1-counter);
	font-weight: normal;
	position: absolute;
	left: 0;
}

h2 {
    font-family: 'Comfortaa-Bold';
    font-size: 11pt;
	font-weight: normal;
	counter-increment: h2-counter;
	counter-reset: h3-counter;
	position: relative; 
	padding-left: 1cm;
}
 
h2::before {
 	content: counter(h1-counter) &quot;.&quot; counter(h2-counter) &quot; &quot;;
    font-size: 11pt;
	font-weight: normal;
	position: absolute;
	left: 0;
}

h3 {
	font-family: 'Segoe UI';
    font-size: 11pt;
	font-weight: normal;
	counter-increment: h3-counter;
	position: relative; 
	padding-left: 1cm;
}
 
h3::before {
 	content: counter(h1-counter) &quot;.&quot; counter(h2-counter) &quot;.&quot; counter(h3-counter) &quot; &quot;;
    font-size: 11pt;
	font-weight: normal;
	position: absolute;
	left: 0;
}

table {
  border-spacing: 0px;
}

.new-page {
    break-after: page; 
}</documentation>
