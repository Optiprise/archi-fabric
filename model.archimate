              <documentation>inhoudsopgave h1::before {
}

.toc-title {
    font-size: 11pt;
    font-family: 'Comfortaa-Bold';
	text-transform: uppercase;
	color: #214478;
}

section.toc {
	break-before: page;
}

ul.toc {
	display: block;
	margin: 1em 0;
}
ul.toc a{
	text-decoration: none;
	color: #000000;
}

ul.toc a::before {
  content: target-text(attr(href)) ' ' leader(' ') ' ' target-counter(attr(href), page);
}

ul.toc li {
  display: block;
}

ul.toc.h1 a {
	color: #214478;
	font-family: 'SegoeUI-Semibold';
	font-size: 11pt;
	font-variant: all-small-caps;
}

ul.toc.h2 a {
	color: #000000;
	font-family: 'SegoeUI';
	font-size: 9pt;
	font-style: italic;
	font-variant: normal;
}</documentation>
